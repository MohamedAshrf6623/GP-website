<%- include('../partials/header') %>

<section class="hero error-page">
  <div class="container">
    <h1><%= statusCode %></h1>
    <h2 style="color: var(--accent);">Oops! Something Went Wrong</h2>
    <p class="lead" style="margin-top: 1rem;">
      <%= message %>
    </p>
    <% if (!isProduction) { %>
      <p style="font-family: monospace; background: #f5f5f5; padding: 1rem; border-radius: 8px; font-size: 0.9rem; color: #d32f2f; margin-top: 1rem; overflow-x: auto;">
        Error details (Dev Mode Only)
      </p>
    <% } %>
    <div style="margin-top: 1.5rem;">
      <a href="/" style="display: inline-block; padding: 0.7rem 1.5rem; background: var(--brand); color: white; border-radius: 999px; text-decoration: none; font-weight: 600;">
        Back to Home
      </a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
